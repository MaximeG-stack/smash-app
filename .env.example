# ==================== DATABASE ====================
DATABASE_URL="postgresql://smashi:smashi_dev_password@localhost:5432/smashi_dev"

# ==================== FIREBASE (backend — service account) ====================
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_KEY=

# ==================== FIREBASE (mobile — EXPO_PUBLIC = côté client) ====================
# À remplir depuis la console Firebase → Paramètres du projet → Tes applications → Web
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ==================== JWT ====================
JWT_SECRET=change_me_in_production_minimum_32_chars
JWT_EXPIRES_IN=7d

# ==================== CLOUDFLARE R2 ====================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=smashi-assets
R2_PUBLIC_URL=

# ==================== GOOGLE SIGN-IN (OAuth) ====================
# Console Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Activer "Google Identity Toolkit API" dans Firebase Console → Authentication → Sign-in method → Google
EXPO_PUBLIC_GOOGLE_CLIENT_ID=          # Web client ID (pour Expo Go / web)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=      # iOS client ID
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=  # Android client ID

# ==================== GOOGLE MAPS ====================
GOOGLE_MAPS_API_KEY=
# Clé publique pour l'app mobile — Console Google Cloud → APIs & Services → Credentials → API Keys
# Activer : Maps SDK for Android, Maps SDK for iOS, Maps JavaScript API, Places API
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# ==================== APP MOBILE ====================
# URL de l'API backend (localhost:3000 en dev)
EXPO_PUBLIC_API_URL=http://localhost:3000

# ==================== STRIPE ====================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ==================== SERVER ====================
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000
